<?xml version="1.0" encoding="UTF-8"?>
<project>

   <modelVersion>4.0.0</modelVersion>

   <parent>
      <groupId>org.rgt</groupId>
      <artifactId>rgt-client-super-pom</artifactId>
      <version>1.16.0.0</version>
   </parent>

   <artifactId>rgt-app-headers</artifactId>
   <version>1.16.0.0</version>

   <packaging>include</packaging>

   <name>RGT - Headers Application ${project.version}</name>

   <properties>
      <project.build.sourceEncoding>IBM850</project.build.sourceEncoding>
   </properties>

   <profiles>
      <profile>
         <id>distribution</id>
         <activation>
            <property>
               <name>distribution</name>
            </property>
         </activation>
         <build>
            <plugins>
               <plugin>
                  <groupId>org.apache.maven.plugins</groupId>
                  <artifactId>maven-antrun-plugin</artifactId>
                  <version>1.8</version>
                  <inherited>false</inherited>
                  <executions>
                     <execution>
                        <id>prepare-distribution</id>
                        <phase>install</phase>
                        <goals>
                           <goal>run</goal>
                        </goals>
                        <configuration>
                           <target name="Copy Headers">
                              <copy todir="../distribution/${project.version}/include" overwrite="true">
                                 <fileset dir="src/main/headers">
                                    <include name="**/*.ch" />
                                 </fileset>
                              </copy>
                           </target>
                        </configuration>
                     </execution>
                  </executions>
               </plugin>
            </plugins>
         </build>
      </profile>
   </profiles>

</project>
